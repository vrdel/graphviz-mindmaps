						:
				# line1
				# line2
				# line3
					: El1p El2c El3y
					# syntax
						: verbatim edgo
						:
						: line1
						: line2
						: line3
						: 	: El1p El2c El3y
						:
					# negative offset with "E"
						: commen edgo
			# individual words
				: w1g w2b
				# syntax
					: verbatim
					:
					: individual words
					:  : w1g w2b
					:
			# first range of words
			# second range of words
				: l1w[2,3,4]g l2w[2-4]r
				# syntax
					: verbatim
					:
					: first range of words
					:   : l1w[2,3,4]g
					:
					: second range of words
					:   : l2w[2-4]g
					:
			# individual words
			# spreaded across
			# multiple lines
				: l1w1g l1w2b l3w1c l3w2p
				# syntax
					: verbatim
					:
					: individual words
					: spreaded across
					: multiple lines
