		# types
		# ---
		# edgd
			: edgd
			# regular text nodes
				:
				# node
					: node
				# comment
					: commen
				# underl
					: underl
				# verbatim
					: verbatim
					:
					: foo bar
					:
			# emphasized
				:
				# quest
					: quest
					# answer
						: answer
				# title
					: title
					# saying
						: saying
				# example
					: example
					# data
						: data
				# term
					: term
				# date
					: date
