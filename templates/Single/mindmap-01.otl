	# subgraphs
		:
		# sgr'this is title'
			: sgr'this is a title'
			# commen
				: commen
			# commen
				: commen
		# sgpd'this is title'
			: sgpd'this is a title'
			# commen
				: commen
			# commen
				: commen
			# notice dashed border
				: w2r
		# start subgrapha s title
		# ---
		# sggtstart"title"
			: sggtstart"title"
			# notice dotted border
				: w2r underl
		# something in between
			: commen
		# end subgrapha
		# ---
		# sggtend"title"
			: sggtend node
	# node text
		:
		# implication
			:
			# arrow ->
				:
				# syntax
					: verbatim
